# ============================================
# AV Download Manager - 应用业务配置
# 文件名: app.env
# 
# 说明：
# - 此文件包含所有应用业务配置（非 Docker 配置）
# - 可通过 Web UI 实时修改，无需重启容器
# - 修改后会自动保存并生效
# - 注意：此文件不是给 Docker 用的，Docker 使用 .env 文件
# ============================================

# --------------------------------------------
# Web UI 配置
# --------------------------------------------
WEB_PASSWORD=admin123
WEB_SECRET_KEY=change-me-in-production-secret-key-2024

# --------------------------------------------
# FreshRSS 配置
# --------------------------------------------
FRESHRSS_URL=https://rss.your-domain.com
FRESHRSS_USERNAME=your_username
FRESHRSS_PASSWORD=your_password

# --------------------------------------------
# JavBus 配置（可选）
# 用于直接从 JavBus 抓取磁力链接
# --------------------------------------------
JAVBUS_BASE_URL=https://www.javbus.com

# --------------------------------------------
# RSSHub 配置（可选）
# 用于磁力链接抓取回退（当 JavBus 直抓失败时）
# --------------------------------------------
RSSHUB_BASE_URL=https://rsshub.your-domain.com

# --------------------------------------------
# BitComet 配置
# --------------------------------------------
BITCOMET_URL=https://bit.your-domain.com:8888
BITCOMET_USERNAME=sandbox
BITCOMET_PASSWORD=your_password

# BitComet 认证信息（通过浏览器抓包获取）
# 步骤：
# 1. 浏览器打开 BitComet WebUI
# 2. 按 F12 → Network 标签
# 3. 登录 BitComet
# 4. 找到 /api/webui/login 请求
# 5. 复制请求体中的 client_id 和 authentication 字段
BITCOMET_CLIENT_ID=
BITCOMET_AUTHENTICATION=

BITCOMET_DOWNLOAD_PATH=/home/sandbox/Downloads

# --------------------------------------------
# JavSP-Web 配置
# --------------------------------------------
JAVSP_URL=http://javsp-web:8090
JAVSP_USERNAME=your_username
JAVSP_PASSWORD=your_password
JAVSP_INPUT_PATH=/video/downloaded
JAVSP_OUTPUT_PATH=/video

# --------------------------------------------
# Jellyfin 配置
# --------------------------------------------
JELLYFIN_URL=https://jellyfin.your-domain.com
JELLYFIN_API_KEY=your_api_key
JELLYFIN_LIBRARY_NAME=video

# --------------------------------------------
# 工作流调度配置（单位：分钟）
# --------------------------------------------
WORKFLOW1_INTERVAL_MINUTES=10
WORKFLOW2_INTERVAL_MINUTES=30
WORKFLOW3_INTERVAL_MINUTES=60

# --------------------------------------------
# JavSP 提交条件配置
# --------------------------------------------
# 分享率阈值（如 2.0 表示 200%）
# 下载完成且分享率超过此值则提交 JavSP 刮削
JAVSP_SUBMIT_SHARE_RATIO=5.0

# 创建时间阈值（小时）
# 下载完成且创建时间超过此值则提交 JavSP 刮削
JAVSP_SUBMIT_HOURS=8

# --------------------------------------------
# 业务逻辑配置
# --------------------------------------------
# 最大保留已完成下载数量（Jellyfin 影片数量限制）
MAX_COMPLETED_DOWNLOADS=50

# 最大重试次数
MAX_RETRY_COUNT=3

# 重试延迟（秒）
RETRY_DELAY_SECONDS=60

# 下载超时时间（小时）
# 超过此时间未完成则标记为 timeout
DOWNLOAD_TIMEOUT_HOURS=48

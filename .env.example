# ============================================
# AV Download Manager - Docker 配置
# 文件名: .env
# 
# 说明：
# - 此文件是给 Docker Compose 使用的
# - 只包含容器启动所需的配置（端口、路径）
# - 业务配置（服务URL、认证等）请使用 app.env
# ============================================

# --------------------------------------------
# 端口映射（宿主机 -> 容器）
# --------------------------------------------
# Web UI 访问端口（Nginx）
WEB_PORT=8091

# FastAPI 调试端口（可选）
API_PORT=8080

# --------------------------------------------
# 数据路径（宿主机路径）
# --------------------------------------------
# 视频根目录，需要包含 downloaded 子目录
# 示例: /path/to/your/video/folder
VIDEO_PATH=/path/to/your/video/directory

# --------------------------------------------
# 容器数据卷路径（容器内路径，一般不需要修改）
# --------------------------------------------
DATABASE_URL=sqlite:///./data/av_downloads.db
LOG_FILE=logs/app.log

# --------------------------------------------
# 日志级别
# --------------------------------------------
LOG_LEVEL=INFO

# --------------------------------------------
# Docker 网络
# --------------------------------------------
# 使用外部网络 av-net（由 AV-Ubuntu 创建）
# 确保先运行: cd /path/to/AV-Ubuntu && docker-compose up -d
